import Dre2 from "@/assets/DreQuan_Priest_02.webp"
import Dre3 from "@/assets/DreQuan_Priest_03.webp"

// Jason Duval
import Jason1 from "@/assets/Jason_Duval_01.webp"
import Jason2 from "@/assets/Jason_Duval_02.webp"
import Jason3 from "@/assets/Jason_Duval_03.webp"
import Jason4 from "@/assets/Jason_Duval_04.webp"
import Jason5 from "@/assets/Jason_Duval_05.webp"
import Jason6 from "@/assets/Jason_Duval_06.webp"

// Lucia Caminos
import Lucia1 from "@/assets/Lucia_Caminos_01.webp"
import Lucia2 from "@/assets/Lucia_Caminos_02.webp"
import Lucia3 from "@/assets/Lucia_Caminos_03.webp"
import Lucia4 from "@/assets/Lucia_Caminos_04.webp"
import Lucia5 from "@/assets/Lucia_Caminos_05.webp"
import Lucia6 from "@/assets/Lucia_Caminos_06.webp"

// Raul Bautista
import Raul1 from "@/assets/Raul_Bautista_01.webp"
import Raul2 from "@/assets/Raul_Bautista_02.webp"
import Raul3 from "@/assets/Raul_Bautista_03.webp"
import Raul4 from "@/assets/Raul_Bautista_04.webp"

// Real Dimez
import Dimez1 from "@/assets/Real_Dimez_01.webp"
import Dimez2 from "@/assets/Real_Dimez_02.webp"
import Dimez3 from "@/assets/Real_Dimez_03.webp"
import Dimez4 from "@/assets/Real_Dimez_04.webp"

//consolas
import PS5 from "@/assets/ps5.svg"
import Xbox from "@/assets/xbox.svg"

//videos
import V_Jason from "@/assets/Jason_Duval_Video_Clip.mp4"
import V_Boobie from "@/assets/Boobie_Ike_Video_Clip.mp4"
import V_Brian from "@/assets/Brian_Heder_Video_Clip.mp4"
import V_Cal from "@/assets/Cal_Hampton_Video_Clip.mp4"
import V_Dre from "@/assets/DreQuan_Priest_Video_Clip.mp4"
import V_Jason from "@/assets/Jason_Duval_Video_Clip.mp4"
import V_Lucia from "@/assets/Lucia_Caminos_Video_Clip.mp4"
