//musica
import musicaSrc from "@/music/queenofhearts.mp3"
// personajes

// Boobie Ike
import Boobie1 from "@/assets/Boobie_Ike_01.webp"
import Boobie2 from "@/assets/Boobie_Ike_02.webp"
import Boobie3 from "@/assets/Boobie_Ike_03.webp"
import Boobie4 from "@/assets/Boobie_Ike_04.webp"

